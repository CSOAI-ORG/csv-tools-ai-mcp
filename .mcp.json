{
  "name": "csv-tools-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 Sovereign AI tools for everyone.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "parse_csv",
      "description": "Parse CSV content and return structured data with statistics.",
      "parameters": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "has_header": {
            "type": "boolean"
          },
          "max_rows": {
            "type": "integer"
          }
        },
        "required": [
          "content"
        ]
      }
    },
    {
      "name": "validate_headers",
      "description": "Validate that CSV headers match expected column names.",
      "parameters": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "expected_headers": {
            "type": "array"
          }
        },
        "required": [
          "content",
          "expected_headers"
        ]
      }
    },
    {
      "name": "detect_delimiter",
      "description": "Auto-detect the delimiter used in a CSV/DSV file.",
      "parameters": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          }
        },
        "required": [
          "content"
        ]
      }
    },
    {
      "name": "convert_to_json",
      "description": "Convert CSV content to JSON array of objects.",
      "parameters": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "has_header": {
            "type": "boolean"
          },
          "max_rows": {
            "type": "integer"
          }
        },
        "required": [
          "content"
        ]
      }
    }
  ]
}